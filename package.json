{
  "name": "sgc-dialing-computer",
  "version": "0.1.0",
  "private": true,
  "description": "Screen-accurate SGC Stargate dialing computer — Three.js PWA",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.js",
    "serve": "bun run scripts/serve.js",
    "preview": "SERVE_DIST=1 bun run scripts/serve.js",
    "build": "bun run scripts/build.js",

    "layout": "node -e \"require('fs').copyFileSync('source/trace.json','public/assets/layout.json')\"",
    "clean": "node scripts/clean.js",
    "trace": "node scripts/trace.js",
    "trace:mask": "node scripts/trace.js mask",
    "trace:schema": "node scripts/trace.js schema",
    "trace:match": "node scripts/trace.js match",
    "grid": "node scripts/grid.js",
    "grid:tiles": "node scripts/grid.js tiles",
    "probe": "node scripts/probe.js",
    "zoom": "node scripts/zoom.js",

    "capture": "bun run scripts/capture.js",
    "diff": "bun run scripts/diff.js",
    "lint": "eslint \"public/src/**/*.js\" \"scripts/**/*.js\"",
    "lint:fix": "eslint \"public/src/**/*.js\" \"scripts/**/*.js\" --fix"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "cdn": {
    "three": "0.184.0",
    "lil-gui": "0.21.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
